  @@index([relatedToType, relatedToId])
}

model CrmTimelineEvent {
  id            String   @id @default(cuid())
  orgId         String
  relatedToType String
  relatedToId   String
  eventType     String // e.g. CREATED, UPDATED, CONVERTED, STAGE_CHANGED
  description   String
  details       Json?
  createdById   String
  createdBy     User     @relation("CrmTimelineCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())

