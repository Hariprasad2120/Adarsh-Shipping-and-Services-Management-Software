// ─── Accounting Module ──────────────────────────────────────────────────────────

model Account {
  id              String   @id @default(cuid())
  orgId           String
  branchId        String?
  accountCode     String
  accountName     String
  parentAccountId String?
  rootType        String // ASSET | LIABILITY | EQUITY | INCOME | EXPENSE
  accountType     String // CASH | BANK | RECEIVABLE | PAYABLE | TAX | SALES | PURCHASE | EXPENSE | FIXED_ASSET | DEPRECIATION | EQUITY | ROUND_OFF | OTHER
  isGroup         Boolean  @default(false)
  isActive        Boolean  @default(true)
  openingDebit    Decimal  @default(0.0) @db.Decimal(18, 4)
  openingCredit   Decimal  @default(0.0) @db.Decimal(18, 4)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch   Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  parent   Account?     @relation("AccountHierarchy", fields: [parentAccountId], references: [id], onDelete: Cascade)
  children Account[]    @relation("AccountHierarchy")

  journalEntryLines JournalEntryLine[]
  glEntries         GeneralLedgerEntry[]
  paymentsFrom      PaymentEntry[]       @relation("PaymentsFrom")
  paymentsTo        PaymentEntry[]       @relation("PaymentsTo")
  taxLines          TaxLine[]

  // New accounting relations
  recurringExpenses       RecurringExpense[]
  recurringJournalsDebit  RecurringJournal[] @relation("RecurringDebit")
  recurringJournalsCredit RecurringJournal[] @relation("RecurringCredit")
  partnerCapitalAccounts  PartnerAccount[]   @relation("PartnerCapital")
  partnerCurrentAccounts  PartnerAccount[]   @relation("PartnerCurrent")

  @@unique([orgId, accountCode])
  @@index([orgId])
  @@index([branchId])
}

model FiscalYear {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  closed    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

model JournalEntry {
  id          String   @id @default(cuid())
  orgId       String
  branchId    String?
  voucherNo   String
  postingDate DateTime @db.Date
  remarks     String?
  status      String   @default("DRAFT") // DRAFT | SUBMITTED | CANCELLED
  totalDebit  Decimal  @default(0.0) @db.Decimal(18, 4)
  totalCredit Decimal  @default(0.0) @db.Decimal(18, 4)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org                Organisation             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch             Branch?                  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  lines              JournalEntryLine[]
  glEntries          GeneralLedgerEntry[]
  payrollBatches     PayrollBatch[]
  assetDepreciations AssetDepreciationEntry[]

  @@unique([orgId, voucherNo])
  @@index([orgId])
  @@index([branchId])
}

model JournalEntryLine {
  id             String  @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal @default(0.0) @db.Decimal(18, 4)
  credit         Decimal @default(0.0) @db.Decimal(18, 4)
  partyType      String? // CUSTOMER | SUPPLIER | EMPLOYEE
  partyId        String?
  remarks        String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
}

model GeneralLedgerEntry {
  id          String   @id @default(cuid())
  orgId       String
  branchId    String?
  postingDate DateTime @db.Date
  accountId   String
  partyType   String? // CUSTOMER | SUPPLIER
  partyId     String?
  voucherType String // JOURNAL_ENTRY | SALES_INVOICE | PURCHASE_INVOICE | PAYMENT_ENTRY
  voucherId   String
  debit       Decimal  @default(0.0) @db.Decimal(18, 4)
  credit      Decimal  @default(0.0) @db.Decimal(18, 4)
  remarks     String?
  isCancelled Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  jobId String?
  job   JobCosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  org            Organisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  account        Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Cascade, map: "GLEntry_JournalEntry_FK")

  @@index([orgId])
  @@index([branchId])
  @@index([accountId])
  @@index([voucherId])
  @@index([journalEntryId])
  @@index([jobId])
}

model SalesInvoice {
  id                String   @id @default(cuid())
  orgId             String
  branchId          String?
  invoiceNumber     String
  customerId        String
  crmDealId         String?
  postingDate       DateTime @db.Date
  dueDate           DateTime @db.Date
  status            String   @default("DRAFT") // DRAFT | UNPAID | PARTLY_PAID | PAID | OVERDUE | CANCELLED
  grandTotal        Decimal  @default(0.0) @db.Decimal(18, 4)
  paidAmount        Decimal  @default(0.0) @db.Decimal(18, 4)
  outstandingAmount Decimal  @default(0.0) @db.Decimal(18, 4)
  discountAmount    Decimal  @default(0.0) @db.Decimal(18, 4)
  taxAmount         Decimal  @default(0.0) @db.Decimal(18, 4)
  remarks           String?
  bankDetails       String?
  manualNotes       String?
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobId String?
  job   JobCosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  org           Organisation        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer      CrmAccount          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal          CrmDeal?            @relation(fields: [crmDealId], references: [id], onDelete: SetNull)
  items         SalesInvoiceItem[]
  taxLines      TaxLine[]
  payments      PaymentAllocation[]
  customerNotes CustomerNote[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId])
  @@index([branchId])
  @@index([customerId])
  @@index([crmDealId])
  @@index([jobId])
}

model SalesInvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  itemName  String
  qty       Float
  rate      Decimal @db.Decimal(18, 4)
  amount    Decimal @db.Decimal(18, 4)
