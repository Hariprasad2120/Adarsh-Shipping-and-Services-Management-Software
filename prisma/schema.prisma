generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Organisation Structure ───────────────────────────────────────────────────

model Organisation {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  active               Boolean  @default(true)
  crmCallRetentionDays Int      @default(90)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  branches    Branch[]
  departments Department[]
  divisions   Division[]
  roles       Role[]
  users       User[]

  appraisalCycles        AppraisalCycle[]
  appraisalSchedules     AppraisalSchedule[]
  appraisalCriteria      AppraisalCriterion[]
  appraisalSelfTemplate  AppraisalSelfTemplate?
  appraisalSettings      OrgAppraisalSettings?
  leaveTypes             LeaveType[]
  holidays               Holiday[]
  notifications          Notification[]
  notificationActivities NotificationActivity[]
  todoTasks              TodoTask[]
  announcements          Announcement[]

  crmApprovalLogs   CrmApprovalLog[]
  crmWorkTimeLogs   CrmWorkTimeLog[]
  biometricSyncLogs BiometricSyncLog[]
  workingCalendar   WorkingCalendar?
  otSettings        OtSettings?

  // Accounting Module Relations
  accounts            Account[]
  fiscalYears         FiscalYear[]
  journalEntries      JournalEntry[]
  generalLedgers      GeneralLedgerEntry[]
  salesInvoices       SalesInvoice[]
  purchaseInvoices    PurchaseInvoice[]
  paymentEntries      PaymentEntry[]
  customerLedgers     CustomerLedgerEntry[]
  supplierLedgers     SupplierLedgerEntry[]
  accountingSettings  AccountingSettings?
  accountingAuditLogs AccountingAuditLog[]
  payrollBatches      PayrollBatch[]
  assets              Asset[]
  assetDepreciations  AssetDepreciationEntry[]
  jobCostings         JobCosting[]
  quotations          Quotation[]
  customerNotes       CustomerNote[]
  vendorNotes         VendorNote[]
  recurringExpenses   RecurringExpense[]
  recurringJournals   RecurringJournal[]
  transactionLock     TransactionLock?
  partnerAccounts     PartnerAccount[]

  chaSettings         ChaSettings?
  chaJobs             ChaJob[]
  chaJobDeletionRequests ChaJobDeletionRequest[]
  chaExpenseRequests  ChaExpenseRequest[]
  chaAuditLogs        ChaAuditLog[]
  chaTeamGroups       ChaTeamGroup[]
  chaBranchNumberingRules ChaBranchNumberingRule[]
  chaShipmentTypes    ChaShipmentType[]
  chaDocumentRequirementCategories ChaDocumentRequirementCategory[]

  // Google Chat Integration
  googleChatSpaces        GoogleChatSpace[]
  googleChatSubscriptions GoogleChatSubscription[]
  googleChatDeliveries    GoogleChatDelivery[]

  // Google Workspace Communication Integration
  googleWorkspaceConnections GoogleWorkspaceConnection[]
  googleWorkspaceSettings    GoogleWorkspaceSetting[]
  jobWorkspaceProfiles       JobWorkspaceProfile[]
  communicationAuditEvents   CommunicationAuditEvent[]

  // Recruit Module
  recruitJobOpenings    RecruitJobOpening[]
  recruitCandidates     RecruitCandidate[]
  recruitApplications   RecruitApplication[]
  recruitAuditEvents    RecruitAuditEvent[]
  recruitSettings       RecruitSetting?
  recruitAutomationRuns RecruitAutomationRun[]

  @@index([slug])
}

model Branch {
  id    String @id @default(cuid())
  orgId String
  name  String
  code  String

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users    User[]
  holidays Holiday[]

  // Accounting Module Relations
  accounts          Account[]
  journalEntries    JournalEntry[]
  generalLedgers    GeneralLedgerEntry[]
  salesInvoices     SalesInvoice[]
  purchaseInvoices  PurchaseInvoice[]
  paymentEntries    PaymentEntry[]
  customerLedgers   CustomerLedgerEntry[]
  supplierLedgers   SupplierLedgerEntry[]
  assets            Asset[]
  jobCostings       JobCosting[]
  quotations        Quotation[]
  customerNotes     CustomerNote[]
  vendorNotes       VendorNote[]
  recurringExpenses RecurringExpense[]
  recurringJournals RecurringJournal[]

  chaJobs                ChaJob[]
  chaBranchNumberingRule ChaBranchNumberingRule?

  @@unique([orgId, code])
  @@index([orgId])
}

model Department {
  id    String @id @default(cuid())
  orgId String
  name  String
  code  String

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  divisions Division[]
  users     User[]

  @@unique([orgId, code])
  @@index([orgId])
}

model Division {
  id           String @id @default(cuid())
  orgId        String
  departmentId String
  name         String

  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users      User[]

  @@unique([departmentId, name])
  @@index([orgId])
  @@index([departmentId])
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id       String  @id @default(cuid())
  orgId    String
  name     String
  isSystem Boolean @default(false)

  org               Organisation         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  permissions       RolePermission[]
  userRoles         UserRole[]
  appraisalCriteria AppraisalCriterion[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  label String
  group String

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  orgId           String?
  email           String   @unique
  passwordHash    String
  name            String
  active          Boolean  @default(true)
  isPlatformAdmin Boolean  @default(false)
  designation     String?
  branchId        String?
  departmentId    String?
  divisionId      String?
  managerId       String?
  tlId            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Personal & Biometric mapping
  employeeNumber Int?      @unique
  firstName      String?
  lastName       String?
  dob            DateTime?
  gender         String?
  photo          String?
  employmentType String?
  personalPhone  String?
  aadhaar        String?
  pan            String?
  uan            String?
  bankName       String?
  bankAccount    String?
  ifsc           String?

  org        Organisation? @relation(fields: [orgId], references: [id])
  branch     Branch?       @relation(fields: [branchId], references: [id])
  department Department?   @relation(fields: [departmentId], references: [id])
  division   Division?     @relation(fields: [divisionId], references: [id])
  manager    User?         @relation("ManagerReports", fields: [managerId], references: [id])
  reports    User[]        @relation("ManagerReports")
  tl         User?         @relation("TLReports", fields: [tlId], references: [id])
  tlReports  User[]        @relation("TLReports")

  roles                  UserRole[]
  notifications          Notification[]
  notificationActivities NotificationActivity[] @relation("NotificationActivityActor")
  employmentRecord       EmploymentRecord?
  documents              Document[]
  todoTasks              TodoTask[]

  // Attendance & OT
  punches                 AttendancePunch[]
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]             @relation("LeaveRequester")
  leaveApprovals          LeaveRequest[]             @relation("LeaveApprover")
  otEntries               OTEntry[]                  @relation("OTEmployee")
  otApprovals             OTEntry[]                  @relation("OTApprover")
  otRecords               OtRecord[]                 @relation("EmployeeOtRecords")
  approvedOts             OtRecord[]                 @relation("OtApprovedBy")
  regularizations         AttendanceRegularization[] @relation("RegularizationEmployee")
  approvedRegularizations AttendanceRegularization[] @relation("RegularizationApprover")
  lopRecords              EmployeeLop[]              @relation("EmployeeLopRecords")
  triggeredSyncs          BiometricSyncLog[]         @relation("TriggeredSyncs")

  // AMS
  appraisals           Appraisal[]                 @relation("AppraisalEmployee")
  appraisalReviews     AppraisalReviewer[]
  managementReviews    ManagementReview[]
  meetingConfirmations AppraisalMeeting[]          @relation("MeetingConfirmedBy")
  meetingMinutes       MeetingMinute[]
  hikeDecisions        HikeDecision[]
  appraisalSchedules   AppraisalSchedule[]
  extensionRequests    AppraisalExtensionRequest[] @relation("ExtRequester")
  decidedExtensions    AppraisalExtensionRequest[] @relation("ExtDecider")
  rescheduledMeetings  MeetingReschedule[]         @relation("RescheduledBy")
  confirmedReschedules MeetingReschedule[]         @relation("RescheduleConfirmer")

  // CRM
  raisedTickets   CrmTicket[]        @relation("TicketRaiser")
  assignedTickets CrmTicket[]        @relation("TicketAssignee")
  ticketComments  CrmTicketComment[] @relation("CommentAuthor")

  passkeyResetRequests  PasskeyResetRequest[] @relation("PasskeyResetUser")
  passkeyResetDecisions PasskeyResetRequest[] @relation("PasskeyResetDecider")
  securityEvents        SecurityEvent[]
  sessions              UserSession[]
  passkeySetupRequired  Boolean?              @default(false)

  // CRM Module Back-Relations
  crmInvoicesApproved      CrmInvoice[]                  @relation("CrmInvoiceApprover")
  crmApprovalLogsActed     CrmApprovalLog[]              @relation("CrmApprovalLogActor")
  crmLeadsOwned            CrmLead[]                     @relation("CrmLeadOwner")
  crmContactsOwned         CrmContact[]                  @relation("CrmContactOwner")
  crmAccountsOwned         CrmAccount[]                  @relation("CrmAccountOwner")
  crmDealsOwned            CrmDeal[]                     @relation("CrmDealOwner")
  crmActivitiesOwned       CrmActivity[]                 @relation("CrmActivityOwner")
  crmInvoicesOwned         CrmInvoice[]                  @relation("CrmInvoiceOwner")
  crmVendorsOwned          CrmVendor[]                   @relation("CrmVendorOwner")
  crmProjectsOwned         CrmProject[]                  @relation("CrmProjectOwner")
  crmNotesCreated          CrmNote[]                     @relation("CrmNoteCreator")
  crmAttachmentsCreated    CrmAttachment[]               @relation("CrmAttachmentCreator")
  crmTimelineCreated       CrmTimelineEvent[]            @relation("CrmTimelineCreator")
  crmJdConfigs             CrmLeadSourceJustdialConfig[] @relation("CrmJdConfigOwner")
  crmExternalLeadsAssigned CrmExternalLeadSnapshot[]     @relation("CrmExternalLeadAssignee")
  crmLeadReminders         CrmLeadReminder[]             @relation("CrmLeadReminderUser")
  crmWorkTimeLogs          CrmWorkTimeLog[]              @relation("CrmWorkTimeLogUser")

  // PeoplePlus HRMS Relations
  hrmsPreferences          EmployeePreference?
  hrmsContact              EmployeeContact?
  hrmsShiftAssignments     ShiftAssignment[]             @relation("UserShiftAssignments")
  hrmsPermissionRequests   AttendancePermissionRequest[] @relation("PermissionEmployee")
  hrmsOnDutyRequests       OnDutyRequest[]               @relation("OnDutyEmployee")
  hrmsTimesheetSubmissions TimesheetSubmission[]         @relation("TimesheetSubmissions")
  hrmsGoals                Goal[]                        @relation("EmployeeGoals")
  hrmsSkills               EmployeeSkill[]               @relation("EmployeeSkills")
  hrmsFeedbacksGiven       PerformanceFeedback[]         @relation("FeedbackGiven")
  hrmsFeedbacksReceived    PerformanceFeedback[]         @relation("FeedbackReceived")
  hrmsSalaryLetters        SalaryRevisionLetter[]        @relation("EmployeeSalaryLetters")
  hrmsCourseEnrollments    CourseEnrollment[]            @relation("CourseEnrollments")
  hrmsSurveyResponses      SurveyResponse[]              @relation("SurveyResponses")
  hrmsCases                HRCase[]                      @relation("HRCaseRaiser")
  hrmsAssignedCases        HRCase[]                      @relation("HRCaseAssignee")
  hrmsLetterRequests       HRLetterRequest[]             @relation("LetterRequests")
  hrmsTravelRequests       TravelRequest[]               @relation("TravelRequests")
  hrmsTasksAssigned        HrmsTask[]                    @relation("HrmsTasksAssigned")
  hrmsTasksCreated         HrmsTask[]                    @relation("HrmsTasksCreated")
  hrmsAuditLogs            HrmsAuditLog[]                @relation("HrmsAuditLogs")
  hrmsWorkReports          WorkReport[]                  @relation("UserWorkReports")

  // Accounting Module Relations
  accountingAuditLogs AccountingAuditLog[]

  // CRM Mobile Call Tracking
  crmCallAttempts  CrmCallAttempt[]           @relation("CrmCallAttemptSalesperson")
  crmCallReviews   CrmCallReview[]            @relation("CrmCallReviewer")
  crmCallAuditLogs CrmCallRecordingAuditLog[] @relation("CrmCallAuditLogUser")

  // Google Workspace Relations
  workspaceConnection      GoogleWorkspaceConnection?
  communicationAuditEvents CommunicationAuditEvent[]

  // Google Chat Integration
  googleChatLink GoogleChatUserLink?

  // Recruit Module (Job Seeker)
  recruitJobSeekerProfile      RecruitJobSeekerProfile?
  recruitJobListings           RecruitJobListing[]
  recruitJobMatches            RecruitJobMatch[]
  recruitJobSeekerResumes      RecruitJobSeekerResume[]
  recruitTailoredResumes       RecruitTailoredResume[]
  recruitCoverLetters          RecruitCoverLetter[]
  recruitJobSeekerApplications RecruitJobSeekerApplication[]
  recruitJobAlerts             RecruitJobAlert[]
  recruitCareerConversations   RecruitCareerConversation[]
  recruitInterviewPreps        RecruitInterviewPrep[]
  recruitPrivateShares         RecruitPrivateShare[]

  // CHA Module Relations
  chaJobsOwned                 ChaJob[]                  @relation("ChaJobPrimaryOwner")
  chaJobsDeleted              ChaJob[]                  @relation("ChaJobDeletedBy")
  chaJobAssignments            ChaJobAssignment[]
  chaJobDeletionRequests       ChaJobDeletionRequest[]   @relation("ChaJobDeletionRequester")
  chaJobDeletionApprovals      ChaJobDeletionRequest[]   @relation("ChaJobDeletionManager")
  chaJobDeletionExecutions     ChaJobDeletionRequest[]   @relation("ChaJobDeletionExecutor")
  chaDocumentVersionsUploaded  ChaDocumentVersion[]
  chaDocumentExceptionsCreated ChaDocumentException[]
  chaChecklistImportsUploaded  ChaChecklistImport[]
  chaChecklistApprovals        ChaChecklistApproval[]
  chaChecklistReworkNotes      ChaChecklistReworkNote[]
  chaFilingHistorySet          ChaFilingDateHistory[]
  chaExpenseRequestsCreated    ChaExpenseRequest[]      @relation("ChaExpenseRequestedBy")
  chaExpensePaymentsMade       ChaExpensePayment[]
  chaExpenseQueriesCreated     ChaExpenseQuery[]        @relation("ChaExpenseQueryAuthor")

  @@index([orgId])
  @@index([isPlatformAdmin, active])
  @@index([email])
  @@index([orgId, active, name])
  @@index([orgId, email])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id             String    @id @default(cuid())
  parentId       String?
  orgId          String?
  userId         String
  kind           String
  title          String
  body           String?
  link           String?
  payload        Json?
  source         String?
  variant        String    @default("secondary")
  appearance     String    @default("solid")
  priority       String    @default("normal")
  requiresAck    Boolean   @default(false)
  presentedAt    DateTime?
  readAt         DateTime?
  acknowledgedAt DateTime?
  dismissedAt    DateTime?
  resentCount    Int       @default(0)
  lastSentAt     DateTime?
  createdAt      DateTime  @default(now())

  org            Organisation?          @relation(fields: [orgId], references: [id])
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent         Notification?          @relation("NotificationResends", fields: [parentId], references: [id], onDelete: SetNull)
  resentChildren Notification[]         @relation("NotificationResends")
  activities     NotificationActivity[]

  @@index([userId, readAt])
  @@index([orgId])
  @@index([userId, dismissedAt, acknowledgedAt])
  @@index([kind, createdAt])
  @@index([source])
  // Covers listActiveUserNotifications: WHERE userId + dismissedAt IS NULL + priority
  @@index([userId, dismissedAt, priority])
  // Covers the presentedAt IS NULL filter used when marking notifications as presented
  @@index([userId, presentedAt])
}

model NotificationActivity {
  id             String   @id @default(cuid())
  notificationId String
  orgId          String?
  actorId        String?
  event          String
  metadata       Json?
  createdAt      DateTime @default(now())

  notification Notification  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  org          Organisation? @relation(fields: [orgId], references: [id])
  actor        User?         @relation("NotificationActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([notificationId, createdAt])
  @@index([orgId, event, createdAt])
  @@index([actorId])
  // Covers the "already displayed?" lookup in listActiveUserNotifications
  @@index([notificationId, actorId, event])
}

model EmailQueue {
  id        String    @id @default(cuid())
  to        String
  subject   String
  html      String
  status    String    @default("pending") // pending | sent | failed
  attempts  Int       @default(0)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([status, attempts])
}

model TodoTask {
  id                  String    @id @default(cuid())
  userId              String
  orgId               String?
  title               String
  description         String?
  dueDate             DateTime? @db.Date
  reminderEnabled     Boolean   @default(false)
  alertAt             DateTime?
  status              String    @default("PENDING") // PENDING | COMPLETED
  completedAt         DateTime?
  alertTriggeredAt    DateTime?
  alertNotificationId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org      Organisation? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  subtasks TodoSubtask[]

  @@index([userId, status, dueDate])
  @@index([userId, reminderEnabled, alertAt])
  @@index([userId, status, reminderEnabled, alertAt, alertTriggeredAt])
  @@index([orgId, alertAt])
}

model TodoSubtask {
  id          String    @id @default(cuid())
  taskId      String
  label       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task TodoTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, order])
  @@index([taskId, completed])
}

// ─── HRMS ─────────────────────────────────────────────────────────────────────

model EmploymentRecord {
  id                   String    @id @default(cuid())
  userId               String    @unique
  joinDate             DateTime
  exitDate             DateTime?
  grade                String?
  ctc                  Float?
  priorExperienceYears Float?    @default(0)
  payrollMeta          Json?

  // Salary breakdown
  basic          Float? @default(0)
  hra            Float? @default(0)
  conveyance     Float? @default(0)
  transport      Float? @default(0)
  travelling     Float? @default(0)
  fixedAllowance Float? @default(0)
  stipend        Float? @default(0)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id         String   @id @default(cuid())
  userId     String
  kind       String // e.g. "offer_letter", "id_proof", "certificate"
  fileKey    String
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model AttendancePunch {
  id     String    @id @default(cuid())
  userId String
  date   DateTime  @db.Date
  inAt   DateTime?
  outAt  DateTime?
  source String    @default("web") // web | biometric | manual

  status              String? // PRESENT | HALF_DAY | ABSENT | HOLIDAY | LEAVE | WEEKLY_OFF
  lateMinutes         Int     @default(0)
  earlyLeavingMinutes Int     @default(0)
  workingHours        Float?
  biometricSynced     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model LeaveType {
  id             String  @id @default(cuid())
  orgId          String
  name           String
  paid           Boolean @default(true)
  defaultBalance Float   @default(0)
  accrualRule    Json? // { frequency: "monthly", amount: 1.5, ... }

  org      Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  balances LeaveBalance[]
  requests LeaveRequest[]

  @@unique([orgId, name])
  @@index([orgId])
}

model LeaveBalance {
  id          String @id @default(cuid())
  userId      String
  leaveTypeId String
  year        Int
  balance     Float

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId, year])
  @@index([userId])
}

model LeaveRequest {
  id          String   @id @default(cuid())
  userId      String
  leaveTypeId String
  fromDate    DateTime @db.Date
  toDate      DateTime @db.Date
  halfDay     Boolean  @default(false)
  status      String   @default("pending") // pending | approved | rejected | cancelled
  approverId  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  approver  User?     @relation("LeaveApprover", fields: [approverId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([userId])
  @@index([approverId])
}

model Holiday {
  id          String   @id @default(cuid())
  orgId       String
  branchId    String?
  date        DateTime @db.Date
  name        String
  holidayType String   @default("COMPANY") // COMPANY | NATIONAL | RESTRICTED | WEEKEND

  org    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch?      @relation(fields: [branchId], references: [id])

  @@index([orgId, date])
}

model OTEntry {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  hours      Float
  approverId String?
  status     String   @default("pending") // pending | approved | rejected
  notes      String?
  createdAt  DateTime @default(now())

  user     User  @relation("OTEmployee", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("OTApprover", fields: [approverId], references: [id])

  @@index([userId])
}

// ─── AMS ──────────────────────────────────────────────────────────────────────

model AppraisalCycle {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  year      Int
  status    String   @default("DRAFT") // DRAFT | ACTIVE | CLOSED
  createdAt DateTime @default(now())

  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  appraisals Appraisal[]

  @@index([orgId, year])
}

model AppraisalSchedule {
  id          String   @id @default(cuid())
  orgId       String
  employeeId  String
  dueDate     DateTime @db.Date
  kind        String // INTERMEDIATE | ANNUAL
  cycleIndex  Int
  status      String   @default("SCHEDULED") // SCHEDULED | GENERATED | CANCELLED
  appraisalId String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee  User         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  appraisal Appraisal?   @relation("ScheduledAppraisal", fields: [appraisalId], references: [id], onDelete: SetNull)

  @@unique([employeeId, dueDate, kind])
  @@index([orgId, dueDate, status])
  @@index([employeeId, status])
}

model AppraisalCriterion {
  id           String  @id @default(cuid())
  orgId        String
  roleId       String?
  parentId     String? // null = topic; non-null = sub-topic
  code         String?
  phase        String  @default("SELF") // SELF | REVIEWER | MANAGEMENT
  label        String
  description  String?
  weight       Float   @default(1)
  group        String  @default("")
  order        Int     @default(0)
  maxPoints    Int     @default(0)
  kind         String  @default("CATEGORY") // CATEGORY | SUPPLEMENTARY
  questions    Json? // string[] — per-category text questions
  meta         Json? // SupplementarySection question meta
  reviewerOnly Boolean @default(false)

  org      Organisation         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role     Role?                @relation(fields: [roleId], references: [id])
  parent   AppraisalCriterion?  @relation("CriterionTree", fields: [parentId], references: [id], onDelete: Cascade)
  children AppraisalCriterion[] @relation("CriterionTree")

  @@unique([orgId, phase, code])
  @@index([orgId, phase])
}

model AppraisalSelfTemplate {
  id        String   @id @default(cuid())
  orgId     String   @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Appraisal {
  id                     String    @id @default(cuid())
  cycleId                String
  employeeId             String
  dueDate                DateTime  @db.Date
  stage                  String    @default("DUE_NOTIFIED")
  // DUE_NOTIFIED | REVIEWERS_ASSIGNED | SELF_ASSESSMENT_OPEN | REVIEWER_RATING
  // | MANAGEMENT_REVIEW | MEETING_PENDING | MEETING_LIVE | HIKE_FINALISATION | CLOSED
  availabilityDeadline   DateTime?
  selfAssessmentDeadline DateTime?
  reviewerRatingDeadline DateTime?
  hikeFinal              Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  cycle              AppraisalCycle              @relation(fields: [cycleId], references: [id])
  employee           User                        @relation("AppraisalEmployee", fields: [employeeId], references: [id])
  reviewers          AppraisalReviewer[]
  selfAssessment     SelfAssessment?
  reviewerRatings    ReviewerRating[]
  managementReviews  ManagementReview[]
  meeting            AppraisalMeeting?
  hikeDecision       HikeDecision?
  auditLog           AppraisalAuditLog[]
  scheduleEntry      AppraisalSchedule?          @relation("ScheduledAppraisal")
  extensionRequests  AppraisalExtensionRequest[]
  meetingReschedules MeetingReschedule[]

  @@unique([cycleId, employeeId])
  @@index([cycleId])
  @@index([employeeId])
}

model AppraisalReviewer {
  id                 String    @id @default(cuid())
  appraisalId        String
  userId             String
  kind               String // HR | TL | MANAGER | MANAGEMENT
  availabilityStatus String    @default("PENDING") // PENDING | AVAILABLE | UNAVAILABLE | FORCED
  decidedAt          DateTime?
  assignedAt         DateTime  @default(now())

  appraisal Appraisal        @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id])
  ratings   ReviewerRating[]

  @@unique([appraisalId, userId])
  @@index([appraisalId])
}

model SelfAssessment {
  id          String    @id @default(cuid())
  appraisalId String    @unique
  answers     Json
  status      String    @default("DRAFT") // DRAFT | SUBMITTED
  editCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  appraisal Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
}

model ReviewerRating {
  id          String    @id @default(cuid())
  appraisalId String
  reviewerId  String
  ratings     Json
  comments    String?
  status      String    @default("DRAFT") // DRAFT | SUBMITTED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  appraisal Appraisal         @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  reviewer  AppraisalReviewer @relation(fields: [reviewerId], references: [id])

  @@unique([appraisalId, reviewerId])
  @@index([appraisalId])
}

model ManagementReview {
  id            String     @id @default(cuid())
  appraisalId   String
  reviewerId    String
  ratings       Json
  proposedDates DateTime[]
  status        String     @default("DRAFT") // DRAFT | SUBMITTED
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  submittedAt   DateTime?

  appraisal Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  reviewer  User      @relation(fields: [reviewerId], references: [id])

  @@unique([appraisalId, reviewerId])
  @@index([appraisalId])
}

model AppraisalMeeting {
  id            String    @id @default(cuid())
  appraisalId   String    @unique
  scheduledAt   DateTime
  confirmedById String
  status        String    @default("SCHEDULED") // SCHEDULED | LIVE | DONE | CANCELLED
  lockedAt      DateTime?
  updatedAt     DateTime  @updatedAt

  appraisal   Appraisal       @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  confirmedBy User            @relation("MeetingConfirmedBy", fields: [confirmedById], references: [id])
  minutes     MeetingMinute[]
}

model MeetingMinute {
  id        String   @id @default(cuid())
  meetingId String
  authorId  String
  role      String // HR | MANAGEMENT | EMPLOYEE
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meeting AppraisalMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author  User             @relation(fields: [authorId], references: [id])

  @@unique([meetingId, authorId, role])
  @@index([meetingId])
}

model HikeDecision {
  id                    String   @id @default(cuid())
  appraisalId           String   @unique
  decidedById           String
  percent               Float
  amount                Float
  effectiveFrom         DateTime @db.Date
  notes                 String?
  finalisedAt           DateTime @default(now())
  slabId                String?
  suggestedPercent      Float?
  suggestedScore        Float?
  suggestedFlooredScore Int?
  suggestedGrade        String?
  previousSalary        Float?
  finalSalary           Float?
  negotiationRemarks    String?
  isLocked              Boolean  @default(true)

  appraisal Appraisal      @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  decidedBy User           @relation(fields: [decidedById], references: [id])
  slab      IncrementSlab? @relation(fields: [slabId], references: [id])
}

model AppraisalAuditLog {
  id          String   @id @default(cuid())
  appraisalId String
  actorId     String?
  actorRole   String?
  action      String?
  fromStage   String?
  toStage     String
  note        String?
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())

  appraisal Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)

  @@index([appraisalId])
}

model OrgAppraisalSettings {
  id                       String   @id @default(cuid())
  orgId                    String   @unique
  availabilityDeadlineDays Int      @default(2)
  reviewerRoleWeights      Json     @default("{\"HR\":1,\"TL\":1,\"MANAGER\":1}")
  updatedAt                DateTime @updatedAt

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model SystemClock {
  id        String    @id @default("global")
  frozenAt  DateTime?
  updatedAt DateTime  @updatedAt
}

model BiometricSyncLog {
  id            String   @id @default(cuid())
  orgId         String
  syncTime      DateTime @default(now())
  status        String // SUCCESS | FAILED
  type          String // MANUAL | AUTO
  triggeredById String?
  recordsSynced Int      @default(0)
  errorMessage  String?

  org         Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  triggeredBy User?        @relation("TriggeredSyncs", fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([orgId])
}

model WorkingCalendar {
  id           String @id @default("global")
  orgId        String @unique
  workStart    String @default("09:00")
  workEnd      String @default("18:00")
  timezone     String @default("Asia/Kolkata")
  graceMinutes Int    @default(15)
  workingDays  String @default("1,2,3,4,5,6") // Monday to Saturday
  breaks       Json? // e.g. Lunch break start/end

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model OtSettings {
  id            String @id @default("global")
  orgId         String @unique
  standardHours Float  @default(8.0)
  otRate        Float  @default(1.5)
  graceMinutes  Int    @default(15)
  compOffSlabs  Json? // comp-off rules/slabs

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model OtRecord {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime @db.Date
  dayType          String   @default("WORKING_DAY") // WORKING_DAY | HOLIDAY | WEEKEND
  hoursWorked      Float
  otHours          Float    @default(0)
  otRatePerHour    Float    @default(0)
  otAmount         Float    @default(0)
  compOffDays      Float    @default(0)
  earlyLeavingMins Int      @default(0)
  approvalStatus   String   @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedById     String?
  approvedBy       User?    @relation("OtApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectionRemarks String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation("EmployeeOtRecords", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model AttendanceRegularization {
  id           String    @id @default(cuid())
  userId       String
  date         DateTime  @db.Date
  requestedIn  DateTime?
  requestedOut DateTime?
  reason       String
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedById String?
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User  @relation("RegularizationEmployee", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("RegularizationApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([userId, date])
}

model EmployeeLop {
  id           String   @id @default(cuid())
  userId       String
  payrollMonth DateTime @db.Date // first day of month
  lopDays      Float
  remarks      String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation("EmployeeLopRecords", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, payrollMonth])
  @@index([payrollMonth])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model IncrementSlab {
  id          String @id @default(cuid())
  label       String
  grade       String @default("")
  minRating   Float
  maxRating   Float
  hikePercent Float

  hikeDecisions HikeDecision[]

  @@index([minRating, maxRating])
}

model AppraisalExtensionRequest {
  id            String    @id @default(cuid())
  appraisalId   String
  requesterId   String
  reason        String
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED
  extendedUntil DateTime?
  decidedById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appraisal Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  requester User      @relation("ExtRequester", fields: [requesterId], references: [id])
  decidedBy User?     @relation("ExtDecider", fields: [decidedById], references: [id])
}

model MeetingReschedule {
  id              String   @id @default(cuid())
  appraisalId     String
  originalDate    DateTime
  newDate         DateTime
  reason          String
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rescheduledById String
  confirmedById   String?
  createdAt       DateTime @default(now())

  appraisal     Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
  rescheduledBy User      @relation("RescheduledBy", fields: [rescheduledById], references: [id])
  confirmedBy   User?     @relation("RescheduleConfirmer", fields: [confirmedById], references: [id])
}

model CrmTicket {
  id          String   @id @default(cuid())
  raisedById  String
  assigneeId  String?
  title       String
  description String
  category    String
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority    String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  raisedBy User               @relation("TicketRaiser", fields: [raisedById], references: [id])
  assignee User?              @relation("TicketAssignee", fields: [assigneeId], references: [id])
  comments CrmTicketComment[]

  @@index([raisedById, status])
  @@index([status, createdAt])
}

model CrmTicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  message   String
  createdAt DateTime @default(now())

  ticket CrmTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User      @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
}

model PasskeyResetRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("PasskeyResetUser", fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING")
  requestedAt DateTime  @default(now())
  decidedAt   DateTime?
  decidedById String?
  decidedBy   User?     @relation("PasskeyResetDecider", fields: [decidedById], references: [id])
  reason      String?

  @@index([status, requestedAt])
  @@index([userId, status])
}

model SecurityEvent {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String?
  event        String
  outcome      String
  ipAddress    String?
  userAgent    String?
  sessionToken String?
  details      Json?
  createdAt    DateTime @default(now())

  @@index([event, outcome, createdAt])
  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([sessionToken, createdAt])
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String    @unique
  loginAt    DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  logoutAt   DateTime?
  status     String    @default("ACTIVE")
  ipAddress  String?
  userAgent  String?
  location   String?

  @@index([userId, status])
  @@index([status, lastSeenAt])
}

// ─── CRM Module Entities ───────────────────────────────────────────────────────

model CrmLead {
  id      String @id @default(cuid())
  orgId   String
  ownerId String
  owner   User   @relation("CrmLeadOwner", fields: [ownerId], references: [id])

  firstName            String?
  lastName             String
  company              String
  designation          String?
  email                String?
  phone                String?
  mobile               String?
  fax                  String?
  website              String?
  source               String? // e.g. Cold Call, Web Site, Partner
  status               String                   @default("NEW") // e.g. NEW, CONTACTED, QUALIFIED, LOST
  industry             String?
  annualRevenue        Float?
  employeeCount        Int?
  rating               String? // e.g. Hot, Warm, Cold
  address              String?
  city                 String?
  state                String?
  country              String?
  pincode              String?
  description          String?
  tags                 String[] // array of tags
  isConverted          Boolean                  @default(false)
  convertedAt          DateTime?
  convertedAccountId   String?
  convertedContactId   String?
  convertedDealId      String?
  crmExternalLead      CrmExternalLeadSnapshot? @relation("CrmExternalLeadToLead")
  enquiryDetails       Json?
  notInterestedReason  String?
  isPerishable         Boolean                  @default(false)
  perishableDetails    Json?
  enquiryRef           String?                  @unique
  isFutureFollowUp     Boolean                  @default(false)
  followUpReminderDate DateTime?
  reminders            CrmLeadReminder[]
  workTimeLogs         CrmWorkTimeLog[]
  crmQuotes            CrmInvoice[]             @relation("CrmLeadQuotes")
  crmCallAttempts      CrmCallAttempt[]         @relation("CrmCallAttemptLead")

  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@index([ownerId])
  @@index([status])
  @@index([orgId, isConverted])
  @@index([orgId, createdAt])
}

model CrmLeadReminder {
  id          String    @id @default(cuid())
  orgId       String
  leadId      String
  userId      String
  alertAt     DateTime
  triggeredAt DateTime?
  status      String    @default("PENDING") // PENDING | TRIGGERED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User    @relation("CrmLeadReminderUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, alertAt])
  @@index([status, alertAt])
}

model CrmContact {
  id      String @id @default(cuid())
  orgId   String
  ownerId String
  owner   User   @relation("CrmContactOwner", fields: [ownerId], references: [id])

  accountId String?
  account   CrmAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  firstName       String?
  lastName        String
  email           String?
  phone           String?
  mobile          String?
  designation     String?
  department      String?
  isDecisionMaker Boolean  @default(false)
  address         String?
  description     String?
  tags            String[]

  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals    CrmDeal[]
  invoices CrmInvoice[]

  @@index([orgId])
  @@index([ownerId])
  @@index([accountId])
}

model CrmAccount {
  id      String @id @default(cuid())
  orgId   String
  ownerId String
  owner   User   @relation("CrmAccountOwner", fields: [ownerId], references: [id])

  name            String
  type            String? // Customer, Partner, Vendor, Prospect
  industry        String?
  website         String?
  phone           String?
  email           String?
  gstin           String?
  billingAddress  String?
  shippingAddress String?
  creditLimit     Float   @default(0.0)
  paymentTerms    String?
  status          String  @default("ACTIVE")

  customerSubType        String? // Business, Individual
  salutation             String? // Mr., Mrs., etc.
  firstName              String?
  lastName               String?
  companyName            String?
  language               String?  @default("English")
  communicationChannels  String[] @default([])
  gstTreatment           String? // Registered Business - Regular, Registered Business - Composition, Unregistered Business, Consumer, Overseas, SEZ
  placeOfSupply          String? // Indian state
  pan                    String?
  taxPreference          String? // Taxable, Tax Exempt
  currency               String?  @default("INR")
  openingBalanceBranch   String?
  openingBalanceAmount   Float?   @default(0.0)
  isPortalEnabled        Boolean  @default(false)
  remarks                String?
  billingAddressDetails  Json?
  shippingAddressDetails Json?

  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts CrmContact[]
  deals    CrmDeal[]
  invoices CrmInvoice[]
  projects CrmProject[]

  // Accounting Module Relations
  salesInvoices   SalesInvoice[]
  customerLedgers CustomerLedgerEntry[]
  quotations      Quotation[]
  customerNotes   CustomerNote[]
  jobCostings     JobCosting[]

  chaJobs ChaJob[]

  @@index([orgId])
  @@index([ownerId])
  @@index([orgId, status])
  @@index([orgId, name])
}

model CrmDeal {
  id      String @id @default(cuid())
  orgId   String
  ownerId String
  owner   User   @relation("CrmDealOwner", fields: [ownerId], references: [id])

  accountId String?
  account   CrmAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId String?
  contact   CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  name              String
  stage             String    @default("PROSPECTING") // e.g. PROSPECTING, QUALIFICATION, PROPOSAL, NEGOTIATION, WON, LOST
  amount            Float     @default(0.0)
  probability       Float     @default(10.0) // 0-100 percentage
  expectedCloseDate DateTime?
  source            String?
  serviceType       String? // Freight Forwarding, Customs, Transportation, Warehousing, CHA, etc.
  logisticsCategory String? // Import, Export
  nextFollowUpDate  DateTime?
  competitor        String?
  lostReason        String?
  description       String?
  tags              String[]

  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices CrmInvoice[]

  // Accounting Module Relations
  salesInvoices SalesInvoice[]

  @@index([orgId])
  @@index([ownerId])
  @@index([accountId])
  @@index([orgId, stage])
  @@index([orgId, expectedCloseDate])
  @@index([orgId, accountId])
}

model CrmActivity {
  id      String @id @default(cuid())
  orgId   String
  ownerId String
  owner   User   @relation("CrmActivityOwner", fields: [ownerId], references: [id])

  type         String // TASK | EVENT | CALL
  title        String
  description  String?
  status       String    @default("NOT_STARTED") // e.g. NOT_STARTED, IN_PROGRESS, COMPLETED, DEFERRED
  priority     String    @default("NORMAL") // e.g. LOW, NORMAL, HIGH
  dueAt        DateTime? // For Tasks
  startAt      DateTime? // For Events
  endAt        DateTime? // For Events
  location     String? // For Events
  callResult   String? // For Calls
  durationMins Int? // For Calls

  // Polymorphic string relation
  relatedToType String?
  relatedToId   String?

  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, status])
  @@index([ownerId])
  @@index([relatedToType, relatedToId])
}

model CrmProduct {
  id          String  @id @default(cuid())
  orgId       String
  name        String
  sku         String  @unique
  category    String? // Freight, Customs, Local Handling, etc.
  price       Float   @default(0.0)
  taxPercent  Float   @default(18.0) // GST default
  active      Boolean @default(true)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model CrmVendor {
  id      String @id @default(cuid())
  orgId   String
  ownerId String
  owner   User   @relation("CrmVendorOwner", fields: [ownerId], references: [id])

  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  gstin       String?
  services    String?
  status      String  @default("ACTIVE")

  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices CrmInvoice[]

  // Accounting Module Relations
  purchaseInvoices  PurchaseInvoice[]
  supplierLedgers   SupplierLedgerEntry[]
  vendorNotes       VendorNote[]
  recurringExpenses RecurringExpense[]

  @@index([orgId])
  @@index([ownerId])
}

model CrmInvoice {
  id      String @id @default(cuid())
  orgId   String
  ownerId String
  owner   User   @relation("CrmInvoiceOwner", fields: [ownerId], references: [id])

  invoiceNumber String    @unique // Auto-generated e.g. INV-1001, QT-1001, SO-1001, PO-1001
  type          String // QUOTE | INVOICE | SALES_ORDER | PURCHASE_ORDER
  date          DateTime  @db.Date
  dueDate       DateTime? @db.Date
  status        String    @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  discount      Float     @default(0.0)
  tax           Float     @default(0.0)
  total         Float     @default(0.0)

  // Approval workflow fields
  approvalStatus String    @default("DRAFT")
  // QUOTE:        DRAFT | PENDING_APPROVAL | APPROVED | REWORK | SENT | CUSTOMER_VIEWED | ACCEPTED | INVOICED | DECLINED
  // SALES_ORDER:  DRAFT | PENDING_APPROVAL | APPROVED | ACTIVE | COMPLETED
  // INVOICE:      DRAFT | PENDING_APPROVAL | APPROVED | SENT | PAID
  submittedAt    DateTime?
  approvedAt     DateTime?
  approvedById   String?
  approvedBy     User?     @relation("CrmInvoiceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvalNote   String? // note from approver (approval message or rejection reason)
  reworkNote     String? // note when sent back for rework
  slaDeadline    DateTime? // SalesOrder: 30 business days from approval

  accountId String?
  account   CrmAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId String?
  contact   CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId    String?
  deal      CrmDeal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  vendorId  String?
  vendor    CrmVendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  crmLeadId String?
  crmLead   CrmLead?    @relation("CrmLeadQuotes", fields: [crmLeadId], references: [id], onDelete: SetNull)

  bankDetails String?
  manualNotes String?
  terms       String?

  referenceNumber          String?
  location                 String?
  placeOfSupply            String?
  portOfLoading            String?
  portOfLoadingCountry     String?
  portOfDischarge          String?
  portOfDestinationCountry String?
  incoterm                 String?
  containerType            String?
  numberOfContainers       Int?
  commodity                String?
  weight                   String?
  discountType             String? @default("percentage")

  createdById String
  updatedById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items        CrmInvoiceItem[]
  approvalLogs CrmApprovalLog[]

  @@index([orgId])
  @@index([orgId, type])
  @@index([ownerId])
  @@index([approvalStatus])
  @@index([approvedById])
  @@index([crmLeadId])
}

model CrmApprovalLog {
  id         String   @id @default(cuid())
  orgId      String
  invoiceId  String
  actorId    String
  fromStatus String
  toStatus   String
  note       String?
  createdAt  DateTime @default(now())

