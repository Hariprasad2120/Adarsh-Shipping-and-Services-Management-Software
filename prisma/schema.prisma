  @@index([invoiceId])
}

model PurchaseInvoice {
  id                String   @id @default(cuid())
  orgId             String
  branchId          String?
  invoiceNumber     String
  supplierId        String
  postingDate       DateTime @db.Date
  dueDate           DateTime @db.Date
  status            String   @default("DRAFT") // DRAFT | UNPAID | PARTLY_PAID | PAID | OVERDUE | CANCELLED
  grandTotal        Decimal  @default(0.0) @db.Decimal(18, 4)
  paidAmount        Decimal  @default(0.0) @db.Decimal(18, 4)
  outstandingAmount Decimal  @default(0.0) @db.Decimal(18, 4)
  discountAmount    Decimal  @default(0.0) @db.Decimal(18, 4)
  taxAmount         Decimal  @default(0.0) @db.Decimal(18, 4)
  remarks           String?
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobId String?
  job   JobCosting? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  org         Organisation          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplier    CrmVendor             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items       PurchaseInvoiceItem[]
  taxLines    TaxLine[]
  payments    PaymentAllocation[]
  vendorNotes VendorNote[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId])
  @@index([branchId])
  @@index([supplierId])
  @@index([jobId])
}

model PurchaseInvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  itemName  String
  qty       Float
  rate      Decimal @db.Decimal(18, 4)
  amount    Decimal @db.Decimal(18, 4)

  purchaseInvoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PaymentEntry {
  id                String   @id @default(cuid())
  orgId             String
  branchId          String?
  paymentType       String // RECEIVE | PAY
  postingDate       DateTime @db.Date
  partyType         String // CUSTOMER | SUPPLIER
  partyId           String
  paidFromAccountId String
  paidToAccountId   String
  amount            Decimal  @db.Decimal(18, 4)
  referenceNo       String?
  remarks           String?
  status            String   @default("DRAFT") // DRAFT | SUBMITTED | CANCELLED
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org         Organisation        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch      Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  paidFrom    Account             @relation("PaymentsFrom", fields: [paidFromAccountId], references: [id], onDelete: Cascade)
  paidTo      Account             @relation("PaymentsTo", fields: [paidToAccountId], references: [id], onDelete: Cascade)
  allocations PaymentAllocation[]

  @@index([orgId])
  @@index([branchId])
}

model PaymentAllocation {
  id                String  @id @default(cuid())
  paymentEntryId    String
  salesInvoiceId    String?
  purchaseInvoiceId String?
  allocatedAmount   Decimal @db.Decimal(18, 4)

  paymentEntry    PaymentEntry     @relation(fields: [paymentEntryId], references: [id], onDelete: Cascade)
  salesInvoice    SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id], onDelete: SetNull)
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)

  @@index([paymentEntryId])
  @@index([salesInvoiceId])
  @@index([purchaseInvoiceId])
}

model TaxLine {
  id                String  @id @default(cuid())
  salesInvoiceId    String?
  purchaseInvoiceId String?
  accountId         String
  taxRate           Float
  taxAmount         Decimal @db.Decimal(18, 4)

  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  salesInvoice    SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id], onDelete: SetNull)
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([salesInvoiceId])
  @@index([purchaseInvoiceId])
}

model CustomerLedgerEntry {
  id          String   @id @default(cuid())
  orgId       String
  branchId    String?
  customerId  String
  postingDate DateTime @db.Date
  voucherType String
  voucherId   String
  debit       Decimal  @default(0.0) @db.Decimal(18, 4)
  credit      Decimal  @default(0.0) @db.Decimal(18, 4)
  remarks     String?
  createdAt   DateTime @default(now())

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch   Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer CrmAccount   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([branchId])
  @@index([customerId])
}

model SupplierLedgerEntry {
  id          String   @id @default(cuid())
  orgId       String
  branchId    String?
  supplierId  String
  postingDate DateTime @db.Date
  voucherType String
  voucherId   String
  debit       Decimal  @default(0.0) @db.Decimal(18, 4)
  credit      Decimal  @default(0.0) @db.Decimal(18, 4)
  remarks     String?
  createdAt   DateTime @default(now())

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch   Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplier CrmVendor    @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([branchId])
  @@index([supplierId])
}

model AccountingSettings {
  id                                      String  @id @default(cuid())
  orgId                                   String  @unique
  defaultReceivableAccountId              String?
  defaultPayableAccountId                 String?
  defaultCashAccountId                    String?
  defaultBankAccountId                    String?
  defaultSalesAccountId                   String?
  defaultPurchaseAccountId                String?
  defaultTaxAccountId                     String?
  defaultRoundOffAccountId                String?
  defaultSalaryExpenseAccountId           String?
  defaultSalaryPayableAccountId           String?
  defaultDepreciationExpenseAccountId     String?
  defaultAccumulatedDepreciationAccountId String?

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model AccountingAuditLog {
  id           String   @id @default(cuid())
  orgId        String
  userId       String
  action       String
  entityType   String
  entityId     String
  beforeValues Json?
  afterValues  Json?
  timestamp    DateTime @default(now())

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
}

model PayrollBatch {
  id             String   @id @default(cuid())
  orgId          String
  month          DateTime @db.Date
  status         String   @default("DRAFT") // DRAFT | FINALIZED | PAID
  totalAmount    Decimal  @default(0.0) @db.Decimal(18, 4)
  journalEntryId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org          Organisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@unique([orgId, month])
  @@index([orgId])
}

model Asset {
  id                             String   @id @default(cuid())
  orgId                          String
  branchId                       String?
  assetName                      String
  assetCode                      String
  purchaseDate                   DateTime @db.Date
  purchaseValue                  Decimal  @db.Decimal(18, 4)
  depreciationMethod             String   @default("STRAIGHT_LINE") // STRAIGHT_LINE
  depreciationRate               Float    @default(10.0)
  accumulatedDepreciation        Decimal  @default(0.0) @db.Decimal(18, 4)
  bookValue                      Decimal  @db.Decimal(18, 4)
  assetAccount                   String?
  depreciationAccount            String?
  accumulatedDepreciationAccount String?
  status                         String   @default("ACTIVE") // ACTIVE | FULLY_DEPRECIATED | SCRAPPED
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  org                 Organisation             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch              Branch?                  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  depreciationEntries AssetDepreciationEntry[]

  @@unique([orgId, assetCode])
  @@index([orgId])
  @@index([branchId])
}

model AssetDepreciationEntry {
  id                 String   @id @default(cuid())
  orgId              String
  assetId            String
  depreciationDate   DateTime @db.Date
  depreciationAmount Decimal  @db.Decimal(18, 4)
  journalEntryId     String?
  createdAt          DateTime @default(now())

  org          Organisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@unique([assetId, depreciationDate])
  @@index([orgId])
  @@index([assetId])
}

// ─── Rebuild & Expanded Accounting Module Models ─────────────────────────────────

model Quotation {
  id              String   @id @default(cuid())
  orgId           String
  branchId        String?
  quotationNumber String
  customerId      String
  postingDate     DateTime @db.Date
  validUntil      DateTime @db.Date
  status          String   @default("DRAFT") // DRAFT | OPEN | CONVERTED | EXPIRED | CANCELLED
  subTotal        Decimal  @default(0.0) @db.Decimal(18, 4)
  discountAmount  Decimal  @default(0.0) @db.Decimal(18, 4)
  taxAmount       Decimal  @default(0.0) @db.Decimal(18, 4)
  grandTotal      Decimal  @default(0.0) @db.Decimal(18, 4)
  terms           String?
  remarks         String?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org      Organisation    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer CrmAccount      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    QuotationItem[]

  @@unique([orgId, quotationNumber])
  @@index([orgId])
  @@index([branchId])
  @@index([customerId])
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  itemName    String
  hsnSac      String?
  qty         Float
  uom         String?
  rate        Decimal @db.Decimal(18, 4)
  discount    Decimal @default(0.0) @db.Decimal(18, 4)
  taxRate     Float   @default(18.0)
  taxAmount   Decimal @default(0.0) @db.Decimal(18, 4)
  amount      Decimal @db.Decimal(18, 4)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model CustomerNote {
  id                String   @id @default(cuid())
  orgId             String
  branchId          String?
  noteNumber        String
  noteType          String // DEBIT | CREDIT
  customerId        String
  originalInvoiceId String?
  postingDate       DateTime @db.Date
  reason            String?
  taxableAmount     Decimal  @default(0.0) @db.Decimal(18, 4)
  taxAmount         Decimal  @default(0.0) @db.Decimal(18, 4)
  grandTotal        Decimal  @default(0.0) @db.Decimal(18, 4)
  status            String   @default("DRAFT") // DRAFT | SUBMITTED | CANCELLED
  remarks           String?
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org             Organisation       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer        CrmAccount         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  originalInvoice SalesInvoice?      @relation(fields: [originalInvoiceId], references: [id], onDelete: SetNull)
  items           CustomerNoteItem[]

  @@unique([orgId, noteNumber])
  @@index([orgId])
  @@index([branchId])
  @@index([customerId])
  @@index([originalInvoiceId])
}

model CustomerNoteItem {
  id             String  @id @default(cuid())
  customerNoteId String
  itemName       String
  qty            Float
  rate           Decimal @db.Decimal(18, 4)
  amount         Decimal @db.Decimal(18, 4)
  taxRate        Float   @default(18.0)
  taxAmount      Decimal @default(0.0) @db.Decimal(18, 4)

  customerNote CustomerNote @relation(fields: [customerNoteId], references: [id], onDelete: Cascade)

  @@index([customerNoteId])
}

model VendorNote {
  id                String   @id @default(cuid())
  orgId             String
  branchId          String?
  noteNumber        String
  noteType          String // DEBIT | CREDIT
  vendorId          String
  originalInvoiceId String?
  postingDate       DateTime @db.Date
  reason            String?
  taxableAmount     Decimal  @default(0.0) @db.Decimal(18, 4)
  taxAmount         Decimal  @default(0.0) @db.Decimal(18, 4)
  grandTotal        Decimal  @default(0.0) @db.Decimal(18, 4)
  status            String   @default("DRAFT") // DRAFT | SUBMITTED | CANCELLED
  remarks           String?
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org             Organisation     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  vendor          CrmVendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  originalInvoice PurchaseInvoice? @relation(fields: [originalInvoiceId], references: [id], onDelete: SetNull)
  items           VendorNoteItem[]

  @@unique([orgId, noteNumber])
  @@index([orgId])
  @@index([branchId])
  @@index([vendorId])
  @@index([originalInvoiceId])
}

model VendorNoteItem {
  id           String  @id @default(cuid())
  vendorNoteId String
  itemName     String
  qty          Float
  rate         Decimal @db.Decimal(18, 4)
  amount       Decimal @db.Decimal(18, 4)
  taxRate      Float   @default(18.0)
  taxAmount    Decimal @default(0.0) @db.Decimal(18, 4)

  vendorNote VendorNote @relation(fields: [vendorNoteId], references: [id], onDelete: Cascade)

  @@index([vendorNoteId])
}

model RecurringExpense {
  id               String    @id @default(cuid())
  orgId            String
  branchId         String?
  templateName     String
  vendorId         String
  expenseAccountId String
  amount           Decimal   @db.Decimal(18, 4)
  taxRate          Float     @default(0.0)
  frequency        String // DAILY | WEEKLY | MONTHLY | QUARTERLY | YEARLY
  startDate        DateTime  @db.Date
  endDate          DateTime? @db.Date
  nextDueDate      DateTime  @db.Date
  narration        String?
  autoPost         Boolean   @default(false)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  org            Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  vendor         CrmVendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  expenseAccount Account      @relation(fields: [expenseAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([branchId])
  @@index([vendorId])
  @@index([expenseAccountId])
}

model RecurringJournal {
  id              String    @id @default(cuid())
  orgId           String
  branchId        String?
  templateName    String
  debitAccountId  String
  creditAccountId String
  amount          Decimal   @db.Decimal(18, 4)
  narration       String?
  frequency       String // DAILY | WEEKLY | MONTHLY | QUARTERLY | YEARLY
  startDate       DateTime  @db.Date
  endDate         DateTime? @db.Date
  nextDueDate     DateTime  @db.Date
  autoPost        Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org           Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  debitAccount  Account      @relation("RecurringDebit", fields: [debitAccountId], references: [id], onDelete: Cascade)
  creditAccount Account      @relation("RecurringCredit", fields: [creditAccountId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([branchId])
  @@index([debitAccountId])
  @@index([creditAccountId])
}

model TransactionLock {
  id        String   @id @default(cuid())
  orgId     String   @unique
  lockDate  DateTime @db.Date
  lockType  String   @default("FULL") // FULL | SOFT
  password  String?
  lockedBy  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model PartnerAccount {
  id                 String   @id @default(cuid())
  orgId              String
  partnerName        String
  partnerCode        String
  capitalAccountId   String
  currentAccountId   String
  profitSharingRatio Float
  interestOnCapital  Float    @default(0.0)
  salary             Decimal  @default(0.0) @db.Decimal(18, 4)
  drawings           Decimal  @default(0.0) @db.Decimal(18, 4)
  interestOnDrawings Float    @default(0.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  org            Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  capitalAccount Account      @relation("PartnerCapital", fields: [capitalAccountId], references: [id], onDelete: Cascade)
  currentAccount Account      @relation("PartnerCurrent", fields: [currentAccountId], references: [id], onDelete: Cascade)

  @@unique([orgId, partnerCode])
  @@index([orgId])
  @@index([capitalAccountId])
  @@index([currentAccountId])
}

model JobCosting {
  id              String    @id @default(cuid())
  orgId           String
  branchId        String?
  jobCode         String
  jobName         String
  customerId      String
  startDate       DateTime  @db.Date
  expectedEndDate DateTime? @db.Date
  actualEndDate   DateTime? @db.Date
  contractValue   Decimal   @default(0.0) @db.Decimal(18, 4)
  status          String    @default("OPEN") // OPEN | IN_PROGRESS | COMPLETED | CLOSED
  costCentre      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch   Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer CrmAccount   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
  glEntries        GeneralLedgerEntry[]

  @@unique([orgId, jobCode])
  @@index([orgId])
  @@index([branchId])
  @@index([customerId])
}
